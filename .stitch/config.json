{
  "projectName": "saas-support-ai",
  "defaultDevice": "DESKTOP",
  "designSystem": {
    "framework": "shadcn/ui",
    "cssFramework": "tailwindcss-v4",
    "primaryColor": "#6366F1",
    "accentColors": ["#8B5CF6", "#06B6D4", "#34D399"],
    "backgroundColor": "#0F172A",
    "surfaceColor": "#1E293B",
    "font": "Syne (headings), Geist (body)"
  },
  "output": {
    "componentsDir": "src/components",
    "pagesDir": "src/app",
    "importAlias": "@/"
  },
  "conventions": {
    "router": "app",
    "useClient": true,
    "typescript": true
  },
  "stitch": {
    "defaultModel": "standard",
    "previewPort": 3333
  }
}
